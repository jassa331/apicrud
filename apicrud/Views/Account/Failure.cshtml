@model apicrud.Models.login

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Account Locked - Crystalline Analytics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
        }

        .login-container {
            display: flex;
            min-height: 100vh;
        }

        .left-panel {
            flex: 1;
            background-color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 50px;
            text-align: center;
        }

            .left-panel h2 {
                font-weight: 700;
                margin-bottom: 20px;
                color: #253b4a;
            }

        .btn-login, .btn-register {
            width: 200px;
            padding: 12px;
            border-radius: 6px;
            font-weight: 600;
            border: none;
            margin: 10px 0;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .btn-login {
            background-color: #253b4a;
            color: #fff;
        }

            .btn-login:hover {
                background-color: #253b4a;
            }

        .btn-register {
            background-color: #f5f5f5;
            color: #1c1c1c;
            border: 1px solid #ccc;
            font-weight: 500;
            transition: background-color 0.3s, transform 0.2s;
        }

            .btn-register:hover {
                background-color: #e0e0e0;
                transform: translateY(-2px);
            }

        .right-panel {
            flex: 1;
            background-color: #253b4a;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

        .info-card {
            background-color: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 30px;
            max-width: 350px;
            text-align: center;
        }

            .info-card h5 {
                font-weight: 600;
            }

            .info-card p {
                font-size: 0.85rem;
                margin-bottom: 10px;
            }

        .info-stats {
            font-size: 1.25rem;
            font-weight: 700;
            margin-top: 10px;
        }

        .info-growth {
            color: #4caf50;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <!-- Left Panel -->
        <div class="left-panel">
            <h2>Your account is locked</h2>
            <p>Please reset your password or go back to login.</p>

            <a asp-action="Login" class="btn-login">Go to Login</a>
            <a asp-action="Forgetpassword" class="btn-register">Reset Password</a>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <div class="info-card">
                <h5>Observe the fluid landscape of global data</h5>
                <p>Total Assets Under Management</p>
                <div class="info-stats">$14.2B <span class="info-growth">+12.4%</span></div>
                <p style="margin-top:15px; font-size:0.75rem;">Join 12,000+ analysts monitoring the crystalline flow.</p>
            </div>
        </div>
    </div>
</body>
</html>