@model BussinessProducts

<h2>Add Product</h2>

<form asp-action="InsertBussinessProducts" method="post">

    <div class="form-group">
        <label>Product Name</label>
        <input asp-for="BussinessProductname" class="form-control" />
    </div>

    <div class="form-group">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="form-group">
        <label>Quantity</label>
        <input asp-for="Quantity" class="form-control" />
    </div>

    <div class="form-group">
        <label>Original Price</label>
        <input asp-for="OriginalPrice" class="form-control" />
    </div>

    <div class="form-group">
        <label>Sell Price</label>
        <input asp-for="SellPrice" class="form-control" />
    </div>

    <div class="form-group">
        <label>Stock</label>
        <input asp-for="stock" class="form-control" />
    </div>

    <div class="form-group">
        <label>Product Type</label>
        <input asp-for="Producttype" class="form-control" />
    </div>

    <div class="form-group">
        <label>Active</label>
        <input asp-for="isactive" type="checkbox" />
    </div>

    <br>

    <button type="submit" class="btn btn-primary">Save Product</button>
    <a asp-controller="infoes" asp-action="InsertBussinessProducts" class="btn btn-primary">
        Add Product
    </a>
</form>