@model IEnumerable<apicrud.Models.info>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <title>User Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        .dashboard-btn {
            width: 190px;
            margin: 10px 20px;
            padding: 10px 15px;
            border: none;
            border-radius: 8px;
            font-weight: 500;
            color: black;
            background: linear-gradient(135deg,white,white);
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
        }

            .dashboard-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 14px rgba(0,0,0,0.2);
            }

        .logout-btn {
            background: linear-gradient(135deg,white,#d63031);
        }

        body {
            background: #f6f7fb;
            font-family: Segoe UI;
        }

        .sidebar {
            width: 230px;
            height: 100vh;
            background: white;
            position: fixed;
            border-right: 1px solid #eee;
            padding-top: 20px;
        }

            .sidebar h4 {
                padding-left: 20px;
                margin-bottom: 25px;
            }

        .dashboard-btn {
            width: 180px;
            margin: 8px 20px;
        }

        .main {
            margin-left: 240px;
            padding: 30px;
        }

        .card-box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .table-box {
            background: white;
            padding: 20px;
            border-radius: 10px;
            margin-top: 20px;
        }

        .status-active {
            background: #d1f5e1;
            color: #0f8a5f;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .status-delete {
            background: #ffd6d6;
            color: #c20000;
            padding: 5px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

    </style>

</head>

<body>

    <!-- Sidebar -->

    <div class="sidebar">

        <h4>Analyst Pro</h4>

        <a asp-action="Create" class="dashboard-btn btn">
            ➕ Add New
        </a>

        <a asp-action="infotable" class="dashboard-btn btn">
            📋 Info Table
        </a>

        <a asp-action="candidates" class="dashboard-btn btn">
            🗑 Deleted Persons
        </a>

        <form asp-controller="Account" asp-action="Logout" method="post">

            <button type="submit" class="dashboard-btn logout-btn">
                🚪 Logout
            </button>

        </form>

    </div>

    <!-- Main Content -->

    <div class="main">

        <h3>User Management Dashboard</h3>
        <p class="text-muted">Real-time oversight of system participants and business entities.</p>

        <!-- Stats Cards -->

        <div class="row mt-4">

            <div class="col-md-3">
                <div class="card-box">
                    <h6>Total Users</h6>
                    <h3>@Model.Count()</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box">
                    <h6>Active Users</h6>
                    <h3>@Model.Count(x => x.IsActive)</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box">
                    <h6>Average Age</h6>
                    <h3>@Model.Average(x => x.age)</h3>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card-box">
                    <h6>Business Types</h6>
                    <h3>@Model.Select(x => x.BusinessName).Distinct().Count()</h3>
                </div>
            </div>

        </div>

        <!-- User Table -->

        <div class="table-box">

            <h5>User Registry</h5>

            <table class="table">

                <thead>

                    <tr>
                        <th>ID</th>
                        <th>User</th>
                        <th>Age</th>
                        <th>Business</th>
                        <th>Gender</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {

                        <tr>

                            <td>@item.ID</td>

                            <td>@item.name</td>

                            <td>@item.age</td>

                            <td>@item.BusinessName</td>

                            <td>@item.Gender</td>

                            <td>

                                @if (item.IsActive)
                                {
                                    <span class="status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-delete">Deleted</span>
                                }

                            </td>

                            <td>@item.CreatedOn?.ToString("dd MMM yyyy")</td>

                            <td>

                                <a asp-action="Edit" asp-route-id="@item.ID" class="btn btn-sm btn-primary">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-danger">
                                    Delete
                                </a>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</body>
</html>