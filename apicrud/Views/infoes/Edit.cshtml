@model InfoViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>info</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @* Hidden ID field *@
            <input type="hidden" asp-for="Info.ID" />
             
            <div class="form-group">
                <label asp-for="Info.name" class="control-label"></label>
                <input asp-for="Info.name" class="form-control" />
                <span asp-validation-for="Info.name" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Info.business" class="control-label"></label>
                <select asp-for="Info.business" class="form-control" asp-items="Model.NameList">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="Info.business" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                 <input type="submit" value="Update" class="btn btn-primary" /> 
               
            </div>
        </form>
    </div>
</div>

