<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @* Hidden ID field *@
            <input type="hidden" asp-for="Info.ID" />
             
            <div class="form-group">
                <label asp-for="Info.name" class="control-label"></label>
                <input asp-for="Info.name" class="form-control" />
                <span asp-validation-for="Info.name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Info.age" class="control-label"></label>
                <input asp-for="Info.age" class="form-control" />
                <span asp-validation-for="Info.age" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Info.business" class="control-label"></label>
                <select asp-for="Info.business" class="form-control" asp-items="Model.NameList">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="Info.business" class="text-danger"></span>
                <div class="form-group">
                    <label asp-for="Info.Gender" class="control-label"></label>
                    <select asp-for="Info.Gender" class="form-control" asp-items="Model.CategoryList">
                        <option value="">-- Select --</option>
                    </select>
                    <span asp-validation-for="Info.Gender" class="text-danger"></span>
                @*     <div class="form-check">
                        <input asp-for="Info.IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="Info.IsActive" class="form-check-label"></label>
                    </div>
                    <span asp-validation-for="Info.IsActive" class="text-danger"></span>
                    <div class="form-check">
                        <input asp-for="Info.IsDeleted" class="form-check-input" type="checkbox" />
                        <label asp-for="Info.IsDeleted" class="form-check-label"></label>
                    </div>
                    <span asp-validation-for="Info.IsDeleted" class="text-danger"></span>
                </div> *@

            <div class="form-group mt-3">
                 <input type="submit" value="Update" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-primary">Back to List</a>

               
            </div>
        </form>
    </div>
</div>

