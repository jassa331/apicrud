@model BussinessProducts
@{
    ViewData["Title"] = "Add Product";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: #f4f6f9;
    }

    .card {
        border-radius: 15px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .card-header {
        background: linear-gradient(90deg, black, #ff4b2b);
        color: white;
        font-weight: bold;
        font-size: 1.4rem;
    }

    .form-control:focus {
        border-color: sky;
        box-shadow: 0 0 0 0.2rem rgba(255, 75, 43, 0.25);
    }

    .btn-success {
        background: linear-gradient(90deg, black, #black);
        border: none;
    }

        .btn-success:hover {
            background: linear-gradient(90deg, black, black);
        }

    .btn-secondary {
        background-color: #6c757d;
    }

    .form-check-input:checked {
        background-color: #ff4b2b;
        border-color: #ff4b2b;
    }
</style>

<div class="container mt-5">
    <div class="card mx-auto" style="max-width: 800px;">
        <div class="card-header text-center">
            <i class="bi bi-box-seam me-2"></i> Add New Product
        </div>
        <div class="card-body">
            <form asp-action="InsertBussinessProducts" method="post">

                <!-- Product Name -->
                <div class="form-floating mb-3">
                    <input asp-for="BussinessProductname" class="form-control" placeholder="Product Name">
                    <label asp-for="BussinessProductname">Product Name</label>
                    <span asp-validation-for="BussinessProductname" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-floating mb-3">
                    <textarea asp-for="Description" class="form-control" placeholder="Product Description" style="height: 100px;"></textarea>
                    <label asp-for="Description">Description</label>
                </div>

                <!-- Quantity / Price -->
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="Quantity" type="number" class="form-control" placeholder="Quantity">
                            <label asp-for="Quantity">Quantity</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="OriginalPrice" type="number" step="0.01" class="form-control" placeholder="Original Price">
                            <label asp-for="OriginalPrice">Original Price</label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="SellPrice" type="number" step="0.01" class="form-control" placeholder="Sell Price">
                            <label asp-for="SellPrice">Sell Price</label>
                        </div>
                    </div>
                </div>

                <!-- Stock / Product Type -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="stock" type="number" class="form-control" placeholder="Stock">
                            <label asp-for="stock">Stock</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Producttype" class="form-control" placeholder="Product Type">
                            <label asp-for="Producttype">Product Type</label>
                        </div>
                    </div>
                </div>

                <!-- Active / Archived -->
                <div class="form-check form-switch mb-3">
                    <input asp-for="isactive" class="form-check-input" type="checkbox" checked>
                    <label asp-for="isactive" class="form-check-label">Active</label>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="isarchived" class="form-check-input" type="checkbox">
                    <label asp-for="isarchived" class="form-check-label">Archived</label>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success btn-lg">Save Product</button>
                    <a asp-action="Dashboard" class="btn btn-secondary btn-lg">Cancel</a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.js"></script>
}