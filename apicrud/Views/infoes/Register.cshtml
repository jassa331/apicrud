@model apicrud.Models.login

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Register - Crystalline Analytics</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f0f2f5;
        }

        .login-container {
            display: flex;
            min-height: 100vh;
        }

        .btn-login, .btn-register {
            width: 100%;
            padding: 12px;
            border-radius: 6px;
            font-weight: 600;
            border: none;
            margin-bottom: 15px;
            cursor: pointer;
        }

        .btn-login {
            background-color: #253b4a;
            color: #fff;
        }

            .btn-login:hover {
                background-color: #253b4a;
            }

        .btn-register {
            background-color: #f5f5f5;
            color: #1c1c1c;
            border: 1px solid #ccc;
            font-weight: 500;
            text-decoration: none;
            display: inline-block;
            transition: background-color 0.3s, transform 0.2s;
        }

            .btn-register:hover {
                background-color: #e0e0e0;
                transform: translateY(-2px);
            }

        .left-panel {
            flex: 1;
            background-color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 50px;
        }

            .left-panel h2 {
                font-weight: 700;
                margin-bottom: 15px;
            }

            .left-panel p {
                color: #6c757d;
                margin-bottom: 30px;
            }

        .form-control {
            border-radius: 6px;
            border: 1px solid #ccc;
            padding: 10px 14px;
            margin-bottom: 20px;
        }

        .checkbox-label {
            display: flex;
            align-items: center;
            font-size: 0.9rem;
            margin-bottom: 25px;
        }

            .checkbox-label input {
                margin-right: 8px;
            }

        .sso-buttons button {
            width: 48%;
            margin-right: 4%;
            border-radius: 6px;
            border: 1px solid #ccc;
            padding: 10px;
            background-color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            cursor: pointer;
        }

            .sso-buttons button:last-child {
                margin-right: 0;
            }

        .right-panel {
            flex: 1;
            background-color: #253b4a;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            padding: 40px;
        }

        .info-card {
            background-color: rgba(255,255,255,0.05);
            border-radius: 12px;
            padding: 30px;
            max-width: 350px;
        }

            .info-card h5 {
                font-weight: 600;
            }

            .info-card p {
                font-size: 0.85rem;
                margin-bottom: 10px;
            }

        .info-stats {
            font-size: 1.25rem;
            font-weight: 700;
            margin-top: 10px;
        }

        .info-growth {
            color: #4caf50;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <!-- Left Panel -->
        <div class="left-panel">
            <h2>Create your account</h2>
            <p>Fill in the details below to register and join the analyst terminal.</p>

            <form asp-action="Register" method="post">
                <label>Institutional Email</label>
                <input asp-for="Email" class="form-control" placeholder="name@crystalline.com" />

                <label>Access Token / Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter access token" />

                <label>Confirm Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Confirm access token" />

                <div class="checkbox-label">
                    <input type="checkbox" /> I agree to the <a href="#">Terms & Conditions</a>
                </div>

                <button type="submit" class="btn-login">Register →</button>

                <!-- LOGIN BUTTON -->
                <a asp-action="Login" class="btn-register" style="display:block; text-align:center; margin-top:10px;">
                    Already have an account? Log in
                </a>

                <div class="sso-buttons mt-3">
                    <button type="button">Google SSO</button>
                    <button type="button">Okta</button>
                </div>

                @if (ViewBag.Error != null)
                {
                    <p class="text-danger">@ViewBag.Error</p>
                }
            </form>
        </div>

        <!-- Right Panel -->
        <div class="right-panel">
            <div class="info-card">
                <h5>Observe the fluid landscape of global data</h5>
                <p>Total Assets Under Management</p>
                <div class="info-stats">$14.2B <span class="info-growth">+12.4%</span></div>
                <p style="margin-top:15px; font-size:0.75rem;">Join 12,000+ analysts monitoring the crystalline flow.</p>
            </div>
        </div>
    </div>
</body>
</html>